Import matplotlib.pyplot as plt
Import networkx as nx 
relation-((1,2),(2,3), (2, 4), (3,1), (3,2), (3,4), (4, 2)
G=nx.Graph()
G.add_edges from(relation) plt.figure(figsize-(6,6))
pos=nx.spring layout (G)
nx.draw (G, pos, with_labels=True, node_color="blue", node_size-1000, font size-15, font weight="bold", edge_color="yellow") plt.title("graph representation") 
plt.show()
